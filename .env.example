# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
# Required. Generate with: openssl rand -base64 33
AUTH_SECRET=

# When deploying behind a proxy or to a non-Vercel host, set this to true.
AUTH_TRUST_HOST=true

# The fully-qualified URL of the deployed app. Required in production; leave
# blank locally (Auth.js falls back to the request Host).
# AUTH_URL=https://nextjs-reference-implementation.example.com

# -----------------------------------------------------------------------------
# Okta OIDC (public client — PKCE, no client secret)
# -----------------------------------------------------------------------------
# From Applications → your OIDC app → General → Client Credentials
AUTH_OKTA_ID=

# Org Authorization Server issuer — do NOT append /oauth2/default.
# Example: https://your-org.okta.com
AUTH_OKTA_ISSUER=

# -----------------------------------------------------------------------------
# Auth debug helpers (leave unset in production)
# -----------------------------------------------------------------------------
# When set, forces the access token to look expired after N seconds so the
# refresh flow fires quickly. Also drives the client-side SessionProvider
# refetch interval so the refreshed token propagates to the browser at a
# matching cadence. NEXT_PUBLIC_ so both server and client can read it.
# NEXT_PUBLIC_AUTH_DEBUG_TTL_SECONDS=60

# When "true", logs fingerprints of the access + refresh tokens on initial
# sign-in and every refresh. Useful for confirming rotation.
# AUTH_DEBUG_LOG_TOKENS=true

# -----------------------------------------------------------------------------
# Artemis GraphQL API
# -----------------------------------------------------------------------------
# Server-side URL used by the Apollo RSC client.
ARTEMIS_GRAPHQL_URL=

# Browser-exposed URL used by the Apollo Client-Component client. Can be the
# same value as ARTEMIS_GRAPHQL_URL if the endpoint is publicly reachable.
NEXT_PUBLIC_ARTEMIS_GRAPHQL_URL=
